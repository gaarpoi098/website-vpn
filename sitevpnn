// SNOW
const canvas=document.getElementById('snow'),ctx=canvas.getContext('2d');
let W,H,flakes=[];
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
window.addEventListener('resize',resize);resize();
const COLS=['rgba(255,77,166,','rgba(255,26,117,','rgba(255,128,192,','rgba(255,220,240,'];
function Flake(){this.reset=function(){this.x=Math.random()*W;this.y=-10;this.r=Math.random()*3.5+1.2;this.speed=Math.random()*1.1+0.35;this.wind=(Math.random()-.5)*.55;this.alpha=Math.random()*.45+.18;this.color=COLS[Math.floor(Math.random()*COLS.length)];this.wobble=Math.random()*Math.PI*2;this.ws=Math.random()*.02+.005;};this.reset();}
for(let i=0;i<120;i++){const f=new Flake();f.y=Math.random()*H;flakes.push(f);}
function drawSnow(){ctx.clearRect(0,0,W,H);for(const f of flakes){ctx.beginPath();ctx.arc(f.x,f.y,f.r,0,Math.PI*2);ctx.fillStyle=f.color+f.alpha+')';ctx.fill();f.y+=f.speed;f.wobble+=f.ws;f.x+=f.wind+Math.sin(f.wobble)*.4;if(f.y>H+10||f.x<-20||f.x>W+20)f.reset();}requestAnimationFrame(drawSnow);}
